# Copy to .env (gitignored) and fill in. All variables are prefixed CPV_.

# eLabFTW API key (raw key, NOT prefixed with "Bearer").
CPV_ELABFTW_API_KEY=

# Optional overrides (defaults come from config.yaml):
# CPV_ELABFTW_HOST=http://localhost:3148/api/v2
# CPV_ELABFTW_EXPERIMENT_ID=1
# CPV_BACKEND=otsu
# CPV_USE_GPU=false
